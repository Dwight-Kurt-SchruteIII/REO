@{
    Layout = "_Layout";
    ViewData["Title"] = "Nájemníci";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 fw-bold mb-1">Nájemníci</h1>
        <p class="text-muted mb-0">Přehled všech nájemníků</p>
    </div>
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createTenantModal">
        <i class="bi bi-plus-lg me-1"></i>Přidat nájemníka
    </button>
</div>

<div class="card border-0 shadow-sm">
    <div id="tenantsList" class="list-group list-group-flush">
        <div class="list-group-item text-muted text-center py-4">
            <span class="spinner-border spinner-border-sm me-2"></span>Načítám...
        </div>
    </div>
</div>

<!-- nájemníci -->
<div class="modal fade" id="createTenantModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="bi bi-person-plus text-primary me-2"></i>Přidat nájemníka
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form id="createTenantForm">
                    <div class="mb-3">
                        <label class="form-label">Jméno</label>
                        <input class="form-control" type="text" name="tenantName" placeholder="Jan Novák" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Nemovitost</label>
                        <select class="form-select" name="propertyId" id="tenantPropertySelect" required>
                            <option value="">Vyberte nemovitost...</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Měsíční nájem (Kč)</label>
                        <input class="form-control" type="number" name="monthlyRent" placeholder="0" min="0" required />
                    </div>
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label">Začátek smlouvy</label>
                            <input class="form-control" type="date" name="startDate" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Konec smlouvy <span class="text-muted">(nepovinné)</span></label>
                            <input class="form-control" type="date" name="endDate" />
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Zrušit</button>
                <button type="submit" form="createTenantForm" class="btn btn-primary">
                    <i class="bi bi-check-lg me-1"></i>Vytvořit nájemníka
                </button>
            </div>
        </div>
    </div>
</div>
