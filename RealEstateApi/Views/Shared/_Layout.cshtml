<!DOCTYPE html>
<html lang="cs">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"] – REO</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/styles.css" asp-append-version="true">
</head>
<body>
    <div class="d-flex">
        <nav class="sidebar bg-dark d-flex flex-column p-0" style="min-height:100vh">
            <div class="sidebar-brand px-4 py-4">
                <i class="bi bi-buildings-fill me-2"></i>REO
            </div>

            <ul class="nav flex-column px-2 mt-1 flex-grow-1">
                <li class="nav-item">
                    <a href="/" class="nav-link nav-link-sidebar">
                        <i class="bi bi-speedometer2 me-2"></i>Přehled
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Properties" class="nav-link nav-link-sidebar">
                        <i class="bi bi-house-door me-2"></i>Nemovitosti
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Tenants" class="nav-link nav-link-sidebar">
                        <i class="bi bi-people me-2"></i>Nájemníci
                    </a>
                </li>
                <li class="nav-item">
                    <a href="/Payments" class="nav-link nav-link-sidebar">
                        <i class="bi bi-credit-card me-2"></i>Platby
                    </a>
                </li>
            </ul>

            <div class="sidebar-footer p-3">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <i class="bi bi-person-circle text-secondary fs-5"></i>
                    <small id="authStatus" class="text-secondary text-truncate">Načítám...</small>
                </div>
                <button id="logoutBtn" class="btn btn-outline-danger btn-sm w-100 hidden">
                    <i class="bi bi-box-arrow-right me-1"></i>Odhlásit se
                </button>
            </div>
        </nav>

        <main class="main-content flex-grow-1 p-4">
            @RenderBody()
        </main>
    </div>

    <div id="toast-container" class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index:9999"></div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/app.js" asp-append-version="true" defer></script>
</body>
</html>
